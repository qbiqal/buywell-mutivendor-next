    <script>
         $(document).ready(function() {
            $('#cart_dropdown_close').on('click', function(e) {
                e.preventDefault();
                $('.cart-dropdown').fadeOut(200).addClass('dismissed');
            });

            $('#cart_items').on('mouseenter', function() {
                $('.cart-dropdown').removeClass('dismissed').removeAttr('style');
            });
        });
    </script>
